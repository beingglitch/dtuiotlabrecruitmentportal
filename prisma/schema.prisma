generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Student {
  id              String   @id @default(cuid())
  fullName        String
  dateOfBirth     String
  gender          String
  email           String   @unique
  phone           String
  address         String
  city            String
  state           String
  program         String
  branch          String
  yearOfStudy     String
  rollNumber      String   @unique
  previousScore   String?
  status          String   @default("pending")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
