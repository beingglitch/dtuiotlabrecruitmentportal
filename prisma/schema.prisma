generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Student {
  id              String   @id @default(cuid())
  fullName        String
  dateOfBirth     String
  gender          String
  email           String   @unique
  phone           String
  address         String
  city            String
  state           String
  program         String
  branch          String
  yearOfStudy     String
  rollNumber      String   @unique
  previousScore   String?

  // Commitment & expectations
  hoursPerWeek        String?
  durationMonths      String?
  workMode            String?
  outcomeGoals        String?   // JSON array of strings

  // Prior experience
  programmingLangs    String?   // JSON array of strings
  hardwareLevel       String?
  toolsKnown          String?   // JSON array of strings
  pastProjects        String?
  githubUrl           String?
  coursework          String?

  // Free-text "other" escape hatches
  otherOutcome        String?
  otherLangs          String?
  otherTools          String?
  additionalInfo      String?

  // Project preferences (JSON object: { [projectId]: priority })
  projectPreferences  String?

  // Open-ended own-project proposal (optional)
  ownProjectTitle        String?
  ownProjectDescription  String?
  ownProjectResources    String?
  ownProjectOutcome      String?

  status          String   @default("pending")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Admin-managed catalog of projects shown on /projects.
// `orderIndex` controls display order (draggable in admin).
// `visible` toggles whether the public page shows it.
model Project {
  id            String   @id @default(cuid())
  slug          String   @unique
  group         String   // "A" or "B"
  title         String
  domain        String
  summary       String
  overview      String   // longer paragraph (shown in detail viewport)
  deliverables  String   // JSON array of strings
  skills        String   // JSON array of strings
  equipment     String
  manpower      String
  timePerWeek   String
  duration      String
  prerequisites String
  outcomes      String   // JSON array of strings
  commercial    String
  stack         String
  orderIndex    Int      @default(0)
  visible       Boolean  @default(true)
  priority      Int      @default(0)   // 0-5 stars; higher = lab wants this filled sooner
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  applications  Application[]

  @@index([visible, orderIndex])
}

// Open submissions for new project ideas, posted via /suggest.
model Suggestion {
  id              String   @id @default(cuid())
  fullName        String
  email           String
  rollNumber      String?
  branch          String?

  title           String
  description     String   // what they want to build, why it matters
  resources       String?  // what they'd need
  expectedOutcome String?  // prototype, paper, demo, etc.

  status          String   @default("new") // new / reviewing / accepted / rejected
  notes           String?  // internal admin notes
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
}

// One submission per student per project (the new per-project flow).
// Old `Student` records are kept for historical reference; new applications
// go here.
model Application {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  fullName        String
  email           String
  phone           String
  rollNumber      String
  branch          String
  yearOfStudy     String

  timeCommit      String?   // hours per week the student can devote
  currentSkills   String?   // free-text
  wantToLearn     String?   // free-text
  previousWork    String?   // free-text
  coursework      String?   // free-text
  whyThisProject  String?   // free-text — the most important field

  status          String    @default("pending")  // pending / shortlisted / accepted / rejected
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([projectId])
  @@index([status])
}
