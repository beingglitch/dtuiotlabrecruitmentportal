generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Student {
  id              String   @id @default(cuid())
  fullName        String
  dateOfBirth     String
  gender          String
  email           String   @unique
  phone           String
  address         String
  city            String
  state           String
  program         String
  branch          String
  yearOfStudy     String
  rollNumber      String   @unique
  previousScore   String?

  // Commitment & expectations
  hoursPerWeek        String?
  durationMonths      String?
  workMode            String?
  outcomeGoals        String?   // JSON array of strings

  // Prior experience
  programmingLangs    String?   // JSON array of strings
  hardwareLevel       String?
  toolsKnown          String?   // JSON array of strings
  pastProjects        String?
  githubUrl           String?
  coursework          String?

  // Free-text "other" escape hatches
  otherOutcome        String?
  otherLangs          String?
  otherTools          String?
  additionalInfo      String?

  // Project preferences (JSON object: { [projectId]: priority })
  projectPreferences  String?

  // Open-ended own-project proposal (optional)
  ownProjectTitle        String?
  ownProjectDescription  String?
  ownProjectResources    String?
  ownProjectOutcome      String?

  status          String   @default("pending")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
