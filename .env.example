# Supabase: Project Settings → Database → Connection string → URI (use the "Transaction" pooler, port 6543)
# It looks like: postgresql://postgres.xxxx:[email protected]:6543/postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# Admin login password for /admin
ADMIN_PASSWORD="change-me-to-something-strong"
